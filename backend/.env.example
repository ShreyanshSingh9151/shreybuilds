# MailPilot AI Backend - Environment Variables
# Copy this file to .env and fill in your values.

# Server
PORT=8080
ENVIRONMENT=development

# CORS origins
CORS_ORIGIN_DASHBOARD=http://localhost:3000
CORS_ORIGIN_EXTENSION=chrome-extension://*

# OpenRouter (primary live gateway)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# OpenRouter-backed logical profiles
OPENROUTER_MODEL_GPT=openai/gpt-4o-mini
OPENROUTER_MODEL_CLAUDE=anthropic/claude-3.5-haiku
OPENROUTER_MODEL_GEMINI=google/gemini-2.0-flash-001

# Backward compatibility (optional)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=meta-llama/llama-3.2-3b-instruct:free

# Legacy direct-provider keys (optional fallback)
CLAUDE_API_KEY=
GEMINI_API_KEY=

# Cost rates per 1K tokens (USD) — used for demo estimation
GPT_COST_PER_1K=0.03
CLAUDE_COST_PER_1K=0.025
GEMINI_COST_PER_1K=0.001
